{
  "manifest_version": 3,
  "name": "TextPlayer",
  "version": "0.1.0",
  "description": "Speed reader — select text on any page and read it at your own pace.",
  "action": {
    "default_title": "TextPlayer"
  },
  "background": {
    "scripts": ["background.js"]
  },
  "commands": {
    "open-textplayer": {
      "suggested_key": { "default": "Alt+Shift+R" },
      "description": "Open TextPlayer"
    }
  },
  "permissions": ["activeTab", "scripting", "storage", "contextMenus"],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "textplayer@local",
      "strict_min_version": "109.0"
    }
  }
}
